# Node
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# SvelteKit
/build
/.svelte-kit
/package
# Sandbox-only workaround residue — when running pnpm check/build
# inside a FUSE-mounted env that disallows unlink, the original
# `.svelte-kit` / `build` dirs get renamed to *.bak / *.tmpsymlink so
# a fresh empty replacement can take over. Never meant to commit.
/.svelte-kit.*
/build.bak
/build.tmpsymlink
.env
.env.*
!.env.example

# Vite
.vite

# Rust / Tauri
/src-tauri/target
/src-tauri/gen

# Editors
.vscode/
.idea/
.claude/
*.swp
*.swo

# Stray temp probe leftover from sandbox FS detection. Cannot unlink
# under FUSE-mounted dev env, so explicitly ignore.
/touchtest

# OS
.DS_Store
Thumbs.db

