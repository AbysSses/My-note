{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyNotes",
  "version": "0.1.0",
  "identifier": "com.yanghc.mynotes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MyNotes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "Productivity",
    "shortDescription": "LYT-based personal knowledge base",
    "longDescription": "A personal cross-platform knowledge base built on pure Markdown and the LYT (Linking Your Thinking) workflow."
  }
}
